@page "/"
@implements IDisposable
@inject Vamsync.Services.AppState AppState
@inject Vamsync.Services.HandyBridgeService Bridge

<PageTitle>VaMSync</PageTitle>

<div class="shell">
    @* ── Header ──────────────────────────────────────── *@
    <header class="header">
        <div class="header-title-group">
            <h1 class="title">
                <span class="title-icon">⚡</span>
                VaMSync
            </h1>
            <p class="subtitle">
                Real-time VaM UDP motion bridge for Handy devices
            </p>
        </div>
        <div class="header-badges">
            <FluentBadge Appearance="Appearance.Neutral"
                         class="version-badge">
                v1.0
            </FluentBadge>
        </div>
    </header>

    @* ── Top Row: Three Status Panels ────────────────── *@
    <FluentGrid Spacing="3" Justify="JustifyContent.FlexStart" Class="top-grid">

        @* ── Handy Connection Panel ──────────────────── *@
        <FluentGridItem xs="12" md="4">
            <FluentCard Class="panel-card connection-card">
                <div class="card-header">
                    <span class="card-icon">🔗</span>
                    <h2 class="card-title">Handy Connection</h2>
                    <FluentBadge Appearance="@(AppState.HandyConnected ? Appearance.Accent : Appearance.Neutral)"
                                 Class="status-dot">
                        @(AppState.HandyConnected ? "Connected" : "Offline")
                    </FluentBadge>
                </div>

                <div class="card-body connection-body">
                    <FluentTextField @bind-Value="_connectionKey"
                                     Placeholder="Paste your Handy connection key"
                                     Label="Connection Key"
                                     Class="connection-input"
                                     Immediate="true" />

                    <div class="button-row">
                        <FluentButton Appearance="Appearance.Accent"
                                      OnClick="VerifyConnectionAsync"
                                      Disabled="_busy"
                                      Class="action-btn">
                            Connect
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Neutral"
                                      OnClick="StartBridgeAsync"
                                      Disabled="_busy"
                                      Class="action-btn">
                            Start
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Neutral"
                                      OnClick="StopBridgeAsync"
                                      Disabled="_busy"
                                      Class="action-btn warn-btn">
                            Stop
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth"
                                      OnClick="ClearConnectionAsync"
                                      Disabled="_busy"
                                      Class="action-btn">
                            Clear
                        </FluentButton>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(AppState.LastError))
                    {
                        <div class="error-banner">
                            <span class="error-icon">⚠</span>
                            @AppState.LastError
                        </div>
                    }
                </div>
            </FluentCard>
        </FluentGridItem>

        @* ── Runtime Status Panel ────────────────────── *@
        <FluentGridItem xs="12" md="4">
            <FluentCard Class="panel-card status-card">
                <div class="card-header">
                    <span class="card-icon">📊</span>
                    <h2 class="card-title">Runtime Status</h2>
                    <FluentBadge Appearance="@(AppState.IsListening ? Appearance.Accent : Appearance.Neutral)"
                                 Class="status-dot">
                        @(AppState.IsListening ? "Active" : "Idle")
                    </FluentBadge>
                </div>

                <div class="card-body">
                    <div class="stat-grid">
                        <div class="stat-row">
                            <span class="stat-label">Listener</span>
                            <span class="stat-value">@AppState.ListenerStatus</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Handy</span>
                            <span class="stat-value @(AppState.HandyConnected ? "val-accent" : "")">@AppState.HandyStatus</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Device</span>
                            <span class="stat-value">@AppState.DeviceInfo</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Mapping</span>
                            <span class="stat-value">@AppState.MappingStatus</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">UDP Rate</span>
                            <span class="stat-value stat-mono">@AppState.UdpPacketsPerSecond <span class="stat-unit">pkt/s</span></span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Total Packets</span>
                            <span class="stat-value stat-mono">@AppState.TotalUdpPacketsReceived.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            </FluentCard>
        </FluentGridItem>

        @* ── Latest Motion Panel ─────────────────────── *@
        <FluentGridItem xs="12" md="4">
            <FluentCard Class="panel-card motion-card">
                <div class="card-header">
                    <span class="card-icon">🎯</span>
                    <h2 class="card-title">Latest Motion</h2>
                    <FluentBadge Appearance="@(AppState.LatestMotion is not null ? Appearance.Accent : Appearance.Neutral)"
                                 Class="status-dot">
                        @(AppState.LatestMotion is not null ? "Live" : "Waiting")
                    </FluentBadge>
                </div>

                <div class="card-body">
                    @if (AppState.LatestMotion is { } motion)
                    {
                        <div class="stat-grid">
                            <div class="stat-row">
                                <span class="stat-label">Position</span>
                                <span class="stat-value stat-mono">@motion.Position <span class="stat-unit">(@motion.NormalizedPosition.ToString("P0"))</span></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Speed</span>
                                <span class="stat-value stat-mono">@motion.Speed <span class="stat-unit">(@motion.NormalizedSpeed.ToString("P0"))</span></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Duration</span>
                                <span class="stat-value stat-mono">@motion.DurationSeconds.ToString("F3")<span class="stat-unit">s</span></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Received</span>
                                <span class="stat-value stat-mono">@motion.ReceivedAt.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-icon">📡</span>
                            <p>Waiting for VaM motion packets…</p>
                        </div>
                    }
                </div>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>

    @* ── Bottom: Activity Log ────────────────────────── *@
    <FluentCard Class="panel-card log-card">
        <div class="card-header">
            <span class="card-icon">📋</span>
            <h2 class="card-title">Activity Log</h2>
            <FluentBadge Appearance="Appearance.Neutral" Class="log-count-badge">
                @AppState.Logs.Count entries
            </FluentBadge>
        </div>

        <div class="log-scroll">
            @if (AppState.Logs.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-icon">📝</span>
                    <p>No activity yet — connect your Handy to get started.</p>
                </div>
            }
            else
            {
                @foreach (var entry in AppState.Logs)
                {
                    <div class="log-entry">
                        <time class="log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</time>
                        <span class="log-msg">@entry.Message</span>
                    </div>
                }
            }
        </div>
    </FluentCard>
</div>

@code {
    private bool _busy;
    private string _connectionKey = string.Empty;

    protected override void OnInitialized()
    {
        _connectionKey = Preferences.Default.Get("handy_connection_key", AppState.ConnectionKey);
        if (!string.IsNullOrWhiteSpace(_connectionKey) && string.IsNullOrWhiteSpace(AppState.ConnectionKey))
        {
            AppState.SetConnectionKey(_connectionKey);
        }

        AppState.Changed += OnAppStateChanged;
    }

    private async Task VerifyConnectionAsync()
    {
        await RunBusyAsync(async () =>
        {
            var connected = await Bridge.ApplyConnectionKeyAsync(_connectionKey);
            if (connected)
            {
                Preferences.Default.Set("handy_connection_key", _connectionKey);
            }
        });
    }

    private async Task StartBridgeAsync()
    {
        await RunBusyAsync(async () =>
        {
            if (!string.IsNullOrWhiteSpace(_connectionKey) && _connectionKey != AppState.ConnectionKey)
            {
                var connected = await Bridge.ApplyConnectionKeyAsync(_connectionKey);
                if (!connected)
                {
                    return;
                }

                Preferences.Default.Set("handy_connection_key", _connectionKey);
            }

            await Bridge.StartAsync();
        });
    }

    private async Task StopBridgeAsync()
    {
        await RunBusyAsync(() => Bridge.StopAsync());
    }

    private async Task ClearConnectionAsync()
    {
        await RunBusyAsync(() =>
        {
            Bridge.ClearConnectionKey();
            _connectionKey = string.Empty;
            Preferences.Default.Remove("handy_connection_key");
            return Task.CompletedTask;
        });
    }

    private async Task RunBusyAsync(Func<Task> work)
    {
        _busy = true;
        try
        {
            await work();
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnAppStateChanged(object? sender, EventArgs e)
    {
        _connectionKey = AppState.ConnectionKey;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.Changed -= OnAppStateChanged;
    }
}
